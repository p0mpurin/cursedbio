# Clerk (optional - keyless mode works without these)
# NEXT_PUBLIC_CLERK_PUBLISHABLE_KEY=pk_test_...
# CLERK_SECRET_KEY=sk_test_...

# Supabase (optional - API works without, but no persistence)
# NEXT_PUBLIC_SUPABASE_URL=https://xxx.supabase.co
# NEXT_PUBLIC_SUPABASE_ANON_KEY=your_anon_key
# SUPABASE_SERVICE_ROLE_KEY=your_service_role_key  (required for save/load - get from Supabase Dashboard > Settings > API)

# App URL for server-side fetches (e.g. bio page, Discord callback)
# NEXT_PUBLIC_APP_URL=http://localhost:3001

# Discord OAuth (for Discord Profile element)
# DISCORD_CLIENT_ID=your_app_id
# DISCORD_CLIENT_SECRET=your_client_secret
# DISCORD_REDIRECT_URI=http://localhost:3001  (base URL; /api/auth/discord/callback is appended)
